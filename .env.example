# FitSphere local development defaults.
# Copy to .env only for Docker Compose overrides. Do not commit real secrets.

POSTGRES_DB=fitSphere
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=fitSphere-auth
KEYCLOAK_CLIENT_ID=oauth2-pkce-client

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESPONSE_TIMEOUT=30s
GEMINI_READ_TIMEOUT=30s
GEMINI_REQUEST_TIMEOUT=35s
GEMINI_RETRIES=1

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
INTERNAL_SERVICE_TOKEN=fitsphere-internal-dev-token
GATEWAY_REQUIRE_HTTPS=false
