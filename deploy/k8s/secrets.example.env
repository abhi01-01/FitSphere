USER_SERVICE_DATASOURCE_URL=jdbc:postgresql://postgres.example.internal:5432/fitsphere
USER_SERVICE_DATASOURCE_USERNAME=fitsphere
USER_SERVICE_DATASOURCE_PASSWORD=replace-me
ACTIVITY_MONGODB_URI=mongodb://activity-user:replace-me@mongo.example.internal:27017/fitSphereActivity?authSource=admin
AI_MONGODB_URI=mongodb://ai-user:replace-me@mongo.example.internal:27017/fitSphereAiService?authSource=admin
RABBITMQ_HOST=rabbitmq.example.internal
RABBITMQ_USERNAME=fitsphere
RABBITMQ_PASSWORD=replace-me
GEMINI_API_KEY=replace-me
KEYCLOAK_JWK_SET_URI=https://keycloak.example.com/realms/fitSphere-auth/protocol/openid-connect/certs
INTERNAL_SERVICE_TOKEN=replace-me-with-a-long-random-shared-token
VITE_API_BASE_URL=https://api.example.com/api
VITE_KEYCLOAK_BASE_URL=https://keycloak.example.com
VITE_KEYCLOAK_REALM=fitSphere-auth
VITE_KEYCLOAK_CLIENT_ID=oauth2-pkce-client
VITE_APP_URL=https://app.example.com
